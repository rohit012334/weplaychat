  "item": [
    {
      "name": "User Auth & Profile",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "key", "value": "{{apiKey}}", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{firebaseIdToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"mobileNumber\": \"9999999999\",\n  \"countryCode\": \"+91\"\n}" },
            "url": { "raw": "{{baseUrl}}/client/user/send-otp", "host": ["{{baseUrl}}"], "path": ["client", "user", "send-otp"] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "key", "value": "{{apiKey}}", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{firebaseIdToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"mobileNumber\": \"9999999999\",\n  \"otp\": \"123456\",\n  \"fcmToken\": \"fcm-token\"\n}" },
            "url": { "raw": "{{baseUrl}}/client/user/verify-otp", "host": ["{{baseUrl}}"], "path": ["client", "user", "verify-otp"] }
          }
        },
        {
          "name": "Quick User Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "key", "value": "{{apiKey}}", "type": "text" }],
            "url": {
              "raw": "{{baseUrl}}/client/user/quickUserVerification?identity={{identity}}",
              "host": ["{{baseUrl}}"],
              "path": ["client", "user", "quickUserVerification"],
              "query": [{ "key": "identity", "value": "{{identity}}" }]
            }
          }
        },
        {
          "name": "Sign In Or Sign Up User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "key", "value": "{{apiKey}}", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{firebaseIdToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"identity\": \"user-unique-id\",\n  \"loginType\": 1,\n  \"email\": \"user@example.com\",\n  \"name\": \"Demo User\",\n  \"fcmToken\": \"fcm-token\"\n}" },
            "url": { "raw": "{{baseUrl}}/client/user/signInOrSignUpUser", "host": ["{{baseUrl}}"], "path": ["client", "user", "signInOrSignUpUser"] }
          }
