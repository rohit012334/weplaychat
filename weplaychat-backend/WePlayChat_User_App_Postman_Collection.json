        {
          "name": "Modify User Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "key", "value": "{{apiKey}}", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{firebaseIdToken}}", "type": "text" },
              { "key": "x-user-uid", "value": "{{userUid}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated User", "type": "text" },
                { "key": "selfIntro", "value": "Hello there", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
