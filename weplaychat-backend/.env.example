# Server
PORT=8000

# MongoDB
MongoDb_Connection_String=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# API shared secret header (used by checkAccess.js)
secretKey=replace_me

# JWT
JWT_SECRET=replace_me

# Cryptr encryption key (must match existing encrypted passwords)
CRYPTR_SECRET=replace_me

# Firebase Admin Service Account (choose ONE)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/or/relative/path/to/serviceAccount.json

# Optional
APP_NAME=WePlayChat
STORAGE_PATH=storage

